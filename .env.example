# Ensmenu Staff BFF
#
# Production PM2 topology (required):
#   staffapi  → PROCESS_ROLE=api    PORT=3010
#   fcm       → PROCESS_ROLE=worker PORT=3011
# Shared PostgreSQL for FCM devices + delivery logs.
# Do not use PROCESS_ROLE=all in production.

PORT=3010
NODE_ENV=development

# Process role: api | worker | all (all = local/dev only; forbidden in production)
PROCESS_ROLE=api

# Express base URL (no trailing slash)
ENS_BACKEND_URL=https://ensapi.ensbot.net
ASSET_PUBLIC_BASE_URL=https://ensapi.ensbot.net

# Socket.IO origin for Worker relays (defaults to ENS_BACKEND_URL)
# ENS_SOCKET_URL=https://ensapi.ensbot.net

# Development may use *. Production MUST set an explicit allowlist (no *).
CORS_ORIGINS=*

# HMAC secret for Express x-api-key (same as Express SECRET_KEY / Owner Gateway)
# Production: min 32 characters.
SECRET_KEY=change-me-min-32-characters-long!!

# Must match Express JWT_ACCESS_SECRET (min 32 chars). Required in production.
# Worker mints staff join JWTs with this secret — parity with Express is mandatory.
JWT_ACCESS_SECRET=change-me-jwt-access-secret-min-32-chars

# Postgres for FCM devices + delivery logs (local docker-compose uses 55433)
DATABASE_URL=postgresql://staff_bff:staff_bff_dev@127.0.0.1:55433/staff_bff?schema=public

# FCM / Firebase Admin (Worker). Keep FCM_ENABLED=false until Firebase is configured.
# Production worker: FCM_ENABLED=true and FCM_DRY_RUN=false
FCM_ENABLED=false
FCM_DRY_RUN=true
# FIREBASE_PROJECT_ID=ensmenu-staff
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Or: FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Seconds added after server clock sync (usually 0)
API_KEY_TIME_OFFSET_SECONDS=0
# Forbidden in production. When true, logs upstream method/path/status only (no bodies).
UPSTREAM_DEBUG_LOG=false
UPSTREAM_TIMEOUT_MS=30000

# Reverse-proxy hops for client IP / rate limiting (0–5). Production default 1.
# TRUST_PROXY_HOPS=1

# Body limits
# REQUEST_JSON_LIMIT=1mb
# REQUEST_URLENCODED_LIMIT=1mb

# Rate limiting
# THROTTLE_TTL_MS=60000
# THROTTLE_LIMIT=120
# THROTTLE_AUTH_TTL_MS=60000
# THROTTLE_AUTH_LIMIT=20
# THROTTLE_HEALTH_TTL_MS=60000
# THROTTLE_HEALTH_LIMIT=60
