# Ensmenu Staff BFF
PORT=3010
NODE_ENV=development

# Express base URL (no trailing slash)
ENS_BACKEND_URL=https://ensapi.ensbot.net
ASSET_PUBLIC_BASE_URL=https://ensapi.ensbot.net

# Development may use *. Production MUST set an explicit allowlist.
CORS_ORIGINS=*

# HMAC secret for Express x-api-key (same as Express SECRET_KEY / Owner Gateway)
SECRET_KEY=change-me-min-32-characters-long!!

# Must match Express JWT_ACCESS_SECRET (min 32 chars). Required in production.
JWT_ACCESS_SECRET=change-me-jwt-access-secret-min-32-chars

# Seconds added after server clock sync (usually 0)
API_KEY_TIME_OFFSET_SECONDS=0
UPSTREAM_DEBUG_LOG=true
UPSTREAM_TIMEOUT_MS=30000

# Reverse-proxy hops for client IP / rate limiting (0–5). Production default 1.
# TRUST_PROXY_HOPS=1

# Body limits
# REQUEST_JSON_LIMIT=1mb
# REQUEST_URLENCODED_LIMIT=1mb

# Rate limiting
# THROTTLE_TTL_MS=60000
# THROTTLE_LIMIT=120
# THROTTLE_AUTH_TTL_MS=60000
# THROTTLE_AUTH_LIMIT=20
# THROTTLE_HEALTH_TTL_MS=60000
# THROTTLE_HEALTH_LIMIT=60
